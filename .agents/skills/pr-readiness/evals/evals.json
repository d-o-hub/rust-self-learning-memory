{
  "tests": [
    {
      "name": "skill-md-present",
      "description": "pr-readiness skill file exists",
      "exec": "test -f .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "requires-merge-state",
      "description": "Documents mergeable and mergeStateStatus (not CI-only)",
      "exec": "rg -q 'mergeStateStatus' .agents/skills/pr-readiness/SKILL.md && rg -q 'mergeable' .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "requires-comment-fetch",
      "description": "Documents fetching PR comments and reviews",
      "exec": "rg -q 'pulls/.*/comments|issues/.*/comments|reviews' .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "cancelled-not-skipped",
      "description": "Documents CANCELLED as non-equivalent to SKIPPED",
      "exec": "rg -q 'CANCELLED' .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "changes-requested-blocker",
      "description": "Documents CHANGES_REQUESTED as merge blocker",
      "exec": "rg -q 'CHANGES_REQUESTED' .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "not-ci-green-only",
      "description": "Rejects CI-green-alone merge recommendation pattern",
      "exec": "rg -q 'CI green|ready to merge|CLEAN' .agents/skills/pr-readiness/SKILL.md"
    },
    {
      "name": "workflow-guards-script",
      "description": "W2.2b cancelled-required guard script exists",
      "exec": "test -x ./scripts/test-workflow-guards.sh && ./scripts/test-workflow-guards.sh --cancelled-required"
    }
  ]
}
