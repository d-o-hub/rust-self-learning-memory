{
  "rules": [
    {
      "skill": "agents-update",
      "triggers": {
        "keywords": ["AGENTS.md", "agent_docs", "guidelines", "update"],
        "patterns": [".*AGENTS.*", "agent_docs/.*"],
        "files": ["AGENTS.md", "agent_docs/**/*.md"]
      },
      "priority": "high"
    },
    {
      "skill": "build-rust",
      "triggers": {
        "keywords": ["build", "cargo build", "compile", "check", "release build"],
        "patterns": ["build-rust\\.sh", "cargo (build|check)"],
        "files": ["**/Cargo.toml", "**/src/**/*.rs", "scripts/build-rust.sh"]
      },
      "priority": "high"
    },
    {
      "skill": "code-quality",
      "triggers": {
        "keywords": ["clippy", "fmt", "format", "lint", "rustfmt", "code quality", "audit"],
        "patterns": ["code-quality\\.sh", "clippy", "rustfmt"],
        "files": ["scripts/code-quality.sh", "**/*.rs"]
      },
      "priority": "high"
    },
    {
      "skill": "test-runner",
      "triggers": {
        "keywords": ["test", "nextest", "doctest", "async", "tokio", "#[tokio::test]"],
        "patterns": ["nextest", "cargo test", "test_.*async"],
        "files": ["**/tests/**/*.rs", "**/src/**/tests.rs", ".config/nextest.toml"]
      },
      "priority": "high"
    },
    {
      "skill": "test-runner",
      "triggers": {
        "keywords": ["benchmark", "proptest", "criterion", "performance test"],
        "patterns": ["bench_.*", "prop_.*"],
        "files": ["benches/**/*.rs"]
      },
      "priority": "medium"
    },
    {
      "skill": "test-fix",
      "triggers": {
        "keywords": ["test fail", "failing test", "flaky test", "fix test"],
        "patterns": ["test-fix", "assert!.*fail"],
        "files": ["**/tests/**/*.rs"]
      },
      "priority": "high"
    },
    {
      "skill": "test-patterns",
      "triggers": {
        "keywords": ["AAA pattern", "proptest", "tokio::test", "test pattern", "write tests"],
        "patterns": ["test-patterns", "#\\[tokio::test\\]"],
        "files": ["**/tests/**/*.rs"]
      },
      "priority": "medium"
    },
    {
      "skill": "ci-fix",
      "triggers": {
        "keywords": ["CI fail", "github actions", "workflow failed", "cancelled check", "Actions"],
        "patterns": ["gh run", "workflow", "\\.github/workflows"],
        "files": [".github/workflows/**/*.yml"]
      },
      "priority": "high"
    },
    {
      "skill": "ci-poll",
      "triggers": {
        "keywords": ["poll CI", "wait for CI", "CI status", "checks pending", "ci-poll"],
        "patterns": ["ci-poll", "statusCheckRollup", "watch.*CI"],
        "files": []
      },
      "priority": "high"
    },
    {
      "skill": "pr-readiness",
      "triggers": {
        "keywords": ["PR ready", "merge", "mergeable", "pr-readiness", "pull request"],
        "patterns": ["mergeStateStatus", "gh pr", "pulls/.*/comments"],
        "files": []
      },
      "priority": "high"
    },
    {
      "skill": "commit",
      "triggers": {
        "keywords": ["commit", "git commit", "conventional commit"],
        "patterns": ["git commit", "feat\\(|fix\\("],
        "files": []
      },
      "priority": "high"
    },
    {
      "skill": "release-guard",
      "triggers": {
        "keywords": ["release", "tag", "publish", "ship", "crates.io", "GitHub Release"],
        "patterns": ["release-manager", "release\\.yml", "v[0-9]+\\.[0-9]+"],
        "files": ["scripts/release-manager.sh", ".github/workflows/release.yml"]
      },
      "priority": "high"
    },
    {
      "skill": "release-cadence-manager",
      "triggers": {
        "keywords": ["release drift", "release-preparation", "cadence", "version_not_advanced"],
        "patterns": ["release-cadence", "commit_limit", "age_limit"],
        "files": ["scripts/release-cadence-manager.sh", "scripts/check-release-drift.sh"]
      },
      "priority": "high"
    },
    {
      "skill": "github-release-best-practices",
      "triggers": {
        "keywords": ["semver", "changelog categories", "release notes structure"],
        "patterns": ["keep a changelog", "semver"],
        "files": ["CHANGELOG.md"]
      },
      "priority": "medium"
    },
    {
      "skill": "goap-agent",
      "triggers": {
        "keywords": ["GOAP", "orchestrat", "multi-step plan", "decompose", "swarm"],
        "patterns": ["goap-agent", "ANALYZE|DECOMPOSE|STRATEGIZE"],
        "files": ["plans/GOAP_*.md", "plans/GOAP_STATE.md"]
      },
      "priority": "high"
    },
    {
      "skill": "agent-coordination",
      "triggers": {
        "keywords": ["agent coordination", "parallel agents", "swarm execution", "quality gates orchestration"],
        "patterns": ["agent-coordination", "execution strateg"],
        "files": []
      },
      "priority": "high"
    },
    {
      "skill": "analysis-swarm",
      "triggers": {
        "keywords": ["analysis swarm", "RYAN", "FLASH", "SOCRATES", "multi-persona"],
        "patterns": ["analysis-swarm"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "architecture-validation",
      "triggers": {
        "keywords": ["architecture validation", "ADR compliance", "plan vs code"],
        "patterns": ["architecture-validation", "plans/adr"],
        "files": ["plans/adr/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "plan-gap-analysis",
      "triggers": {
        "keywords": ["gap analysis", "plan gap", "missing implementation"],
        "patterns": ["plan-gap", "GAP_ANALYSIS"],
        "files": ["plans/STATUS/GAP_ANALYSIS_LATEST.md", "plans/**/*.md"]
      },
      "priority": "medium"
    },
    {
      "skill": "github-workflows",
      "triggers": {
        "keywords": ["workflow", "github actions", "yaml workflow", "gha"],
        "patterns": ["\\.github/workflows"],
        "files": [".github/workflows/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "feature-implement",
      "triggers": {
        "keywords": ["implement feature", "new module", "add API", "feature"],
        "patterns": ["feature-implement"],
        "files": ["memory-core/src/**", "memory-mcp/src/**", "memory-cli/src/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "debug-troubleshoot",
      "triggers": {
        "keywords": ["deadlock", "panic", "segfault", "race", "debug", "hang"],
        "patterns": ["tokio::", "spawn_blocking"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "web-doc-resolver",
      "triggers": {
        "keywords": ["fetch", "documentation", "web", "search", "url", "markdown", "llms.txt"],
        "patterns": ["docs\\..*", "readme", "tutorial", "guide"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "do-memory-cli-ops",
      "triggers": {
        "keywords": ["do-memory-cli", "episode create", "CLI command", "memory cli"],
        "patterns": ["do-memory-cli"],
        "files": ["memory-cli/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "do-memory-mcp",
      "triggers": {
        "keywords": ["MCP", "mcp server", "tool call", "query_memory"],
        "patterns": ["do-memory-mcp", "execute_agent_code"],
        "files": ["memory-mcp/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "codebase-analyzer",
      "triggers": {
        "keywords": ["analyze codebase", "trace data flow", "technical debt", "how does"],
        "patterns": ["codebase-analyzer"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "external-signal-provider",
      "triggers": {
        "keywords": ["external signal", "AgentFS", "reward signal", "toolcall audit"],
        "patterns": ["external-signal", "AgentFS"],
        "files": ["memory-core/src/**/external*", "memory-mcp/**/external*"]
      },
      "priority": "medium"
    },
    {
      "skill": "git-worktree-manager",
      "triggers": {
        "keywords": ["worktree", "git worktree", "isolated branch"],
        "patterns": ["worktree"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "learn",
      "triggers": {
        "keywords": ["record lesson", "session learning", "LESSONS.md"],
        "patterns": ["learn skill", "agent_docs/LESSONS"],
        "files": ["agent_docs/LESSONS.md"]
      },
      "priority": "low"
    },
    {
      "skill": "loop-agent",
      "triggers": {
        "keywords": ["iterative refinement", "loop until", "progressive improvement"],
        "patterns": ["loop-agent"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "memory-context",
      "triggers": {
        "keywords": ["retrieve memory", "semantic search", "context compaction", "episode retrieval"],
        "patterns": ["memory-context", "query_memory"],
        "files": []
      },
      "priority": "medium"
    },
    {
      "skill": "memory-harness",
      "triggers": {
        "keywords": ["memory harness", "replay session", "export fixtures", "benchmark CLI"],
        "patterns": ["memory-harness", "replay-trace"],
        "files": [".agents/skills/memory-harness/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "performance",
      "triggers": {
        "keywords": ["benchmark", "criterion", "performance regression", "profiling"],
        "patterns": ["criterion", "perf"],
        "files": ["benches/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "skill-creator",
      "triggers": {
        "keywords": ["create skill", "new skill", "skill scaffold"],
        "patterns": ["skill-creator"],
        "files": [".agents/skills/**"]
      },
      "priority": "medium"
    },
    {
      "skill": "storage-sync",
      "triggers": {
        "keywords": ["storage sync", "turso redb", "cache stale", "synchronize backends"],
        "patterns": ["storage sync", "StorageSynchronizer"],
        "files": ["memory-storage-*/**", "memory-cli/src/commands/storage/**"]
      },
      "priority": "medium"
    }
  ]
}
