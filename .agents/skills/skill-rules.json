{
  "rules": [
    {
      "skill": "agents-update",
      "triggers": {
        "keywords": ["AGENTS.md", "agent_docs", "guidelines", "update"],
        "patterns": [".*AGENTS.*", "agent_docs/.*"],
        "files": ["AGENTS.md", "agent_docs/**/*.md"]
      },
      "priority": "high"
    },
    {
      "skill": "rust-async-testing",
      "triggers": {
        "keywords": ["async", "tokio", "test", "await", "#[tokio::test]"],
        "patterns": ["test_.*async", ".*_async_test"],
        "files": ["**/tests/**/*.rs", "**/src/**/tests.rs"]
      },
      "priority": "high"
    },
    {
      "skill": "episodic-memory-testing",
      "triggers": {
        "keywords": ["episode", "pattern", "reward", "memory", "extraction"],
        "patterns": ["test_episode_.*", "test_pattern_.*"],
        "files": ["memory-core/**/*.rs"]
      },
      "priority": "high"
    },
    {
      "skill": "test-optimization",
      "triggers": {
        "keywords": ["nextest", "benchmark", "proptest", "criterion", "optimize"],
        "patterns": ["bench_.*", "prop_.*"],
        "files": ["benches/**/*.rs", ".config/nextest.toml"]
      },
      "priority": "medium"
    },
    {
      "skill": "web-doc-resolver",
      "triggers": {
        "keywords": ["fetch", "documentation", "web", "search", "url", "markdown"],
        "patterns": ["docs\\..*", "readme", "tutorial", "guide"],
        "files": []
      },
      "priority": "medium"
    }
  ]
}
