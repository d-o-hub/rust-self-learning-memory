# Environment variables for Memory CLI
# Copy this file to .env and fill in your values

# Turso Database Configuration
TURSO_DATABASE_URL=libsql://rust-self-learning-memory-d-o-hub.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Local Database Path
LOCAL_DATABASE_URL=sqlite:./data/memory.db
MEMORY_REDB_PATH=./data/memory.redb

# Logging Configuration
RUST_LOG=info
MEMORY_LOG_LEVEL=info

# Memory Configuration
MEMORY_MAX_EPISODES_CACHE=1000
MEMORY_CACHE_TTL_SECONDS=3600

# CLI Configuration
MEMORY_CLI_CONFIG=./memory-cli.toml
MEMORY_CLI_FORMAT=human
MEMORY_CLI_PROGRESS_BARS=true
MEMORY_CLI_BATCH_SIZE=100

# Backup Configuration
MEMORY_BACKUP_DIR=./backups
MEMORY_BACKUP_COMPRESS=true

# Embeddings
EMBEDDING_PROVIDER=openai|mistral|azure|local
OPENAI_API_KEY=sk-your-key
MISTRAL_API_KEY=your-mistral-key
AZURE_OPENAI_API_KEY=your-azure-key
OPENAI_API_KEY_ENV=OPENAI_API_KEY
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_SIMILARITY_THRESHOLD=0.7
EMBEDDING_BATCH_SIZE=32

# Monitoring (future features)
# MEMORY_METRICS_PORT=9090
# MEMORY_HEALTH_CHECK_INTERVAL=30

# Security (if applicable)
# MEMORY_ENCRYPTION_KEY=your-encryption-key-here
