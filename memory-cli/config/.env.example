# Memory CLI Environment Variables Example
# =========================================
# Copy this file to .env and customize for your environment
# Never commit .env to version control!

# Configuration file path (optional)
# If not set, memory-cli will look for config files in standard locations
# MEMORY_CLI_CONFIG=./memory-cli.toml

# Turso Database Configuration
# Use these environment variables for security instead of hardcoding in config
TURSO_AUTH_TOKEN=your-turso-auth-token-here
TURSO_DATABASE_URL=libsql://rust-self-learning-memory-d-o-hub.aws-eu-west-1.turso.io

# Local SQLite Configuration (optional)
# LOCAL_DATABASE_URL=sqlite:./data/memory.db
# MEMORY_REDB_PATH=./data/memory.redb

# CLI Options (override config file)
# MEMORY_CLI_FORMAT=json
# MEMORY_CLI_LOG_LEVEL=info
# MEMORY_CLI_PROGRESS_BARS=false

# Monitoring and Health Checks
# MEMORY_CLI_HEALTH_CHECK_INTERVAL=60

# Backup Configuration
# MEMORY_CLI_BACKUP_DIR=./backups
# MEMORY_CLI_BACKUP_MAX_AGE_DAYS=30

# Advanced Settings
# MEMORY_CLI_CACHE_SIZE=1000
# MEMORY_CLI_CACHE_TTL=3600
# MEMORY_CLI_POOL_SIZE=10

# Embeddings (optional)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# MISTRAL_API_KEY=your-mistral-key
# AZURE_OPENAI_API_KEY=your-azure-key
# OPENAI_API_KEY_ENV=OPENAI_API_KEY
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_SIMILARITY_THRESHOLD=0.7
# EMBEDDING_BATCH_SIZE=32

# Development/Debug
# RUST_LOG=memory_cli=debug,memory_core=debug
# RUST_BACKTRACE=1
